{
  // --- clangd (uses build/compile_commands.json for include resolution) ---
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build",
    "--background-index",
    "--header-insertion=iwyu",
    "--completion-style=detailed",
    "--clang-tidy",
    "--pretty"
  ],

  // Avoid the Microsoft C/C++ extension's IntelliSense fighting clangd.
  "C_Cpp.intelliSenseEngine": "disabled",

  // --- formatting: match the repo's Google .clang-format ---
  "editor.formatOnSave": true,
  "[cpp]": { "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd" },
  "[c]": { "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd" },

  // --- CMake integration (build dir already configured) ---
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.configureOnOpen": false
}
